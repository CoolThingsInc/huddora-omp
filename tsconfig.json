{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"rootDir": "src",
		"outDir": "dist",
		"noEmitOnError": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"types": ["bun"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts", "dist", "node_modules"]
}
